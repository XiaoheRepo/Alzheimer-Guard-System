@echo off
:: 设置字符集为 UTF-8 防止中文乱码
chcp 65001 >nul
title Alzheimer System - 本地开发安全隧道
color 0B

echo ===================================================
echo      阿尔兹海默症协同寻回系统 - 生产环境安全隧道
echo ===================================================
echo.
echo 正在准备连接至阿里云服务器...
echo.

:: ===================================================
:: ↓↓↓↓↓ 请在这里修改为你自己的真实配置 ↓↓↓↓↓
:: ===================================================

:: 1. 你的阿里云服务器公网 IP 地址
set SERVER_IP=120.26.72.225

:: 2. 你的服务器登录用户名 (通常是 root)
set SERVER_USER=root

:: 3. 你的私钥文件在本地的绝对路径 (注意：路径最好保留双引号，防止有空格)
set PRIVATE_KEY_PATH="D:\Download\主机A.pem"

:: ===================================================
:: ↑↑↑↑↑ 配置修改到此结束 ↑↑↑↑↑
:: ===================================================

echo [网络映射] 正在打通 本地 5432 -^> 远程 PostgreSQL (5432)
echo [网络映射] 正在打通 本地 6379 -^> 远程 Redis (6379)
echo.
echo ===================================================
echo 【注意】请保持此窗口处于打开状态！
echo 【操作】开发完毕后，直接关闭此黑窗口即可断开连接。
echo ===================================================
echo.

:: 执行 SSH 端口转发
:: -i: 指定私钥
:: -N: 仅做端口转发，不打开远程命令终端
:: (这里没有加 -f，所以进程会锁在这个窗口，方便你随时关掉)
ssh -i %PRIVATE_KEY_PATH% -N -L 5432:127.0.0.1:5432 -L 6379:127.0.0.1:6379 %SERVER_USER%@%SERVER_IP%

echo.
echo [警告] 隧道已断开！请检查网络是否异常，或按任意键退出。
pause